# ============================================
# Lampung Infrastructure Monitor - Configuration
# ============================================

# Aplikasi
APP_NAME=Lampung Infrastructure Monitor
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=true

# Security - GANTI DENGAN RANDOM SECRET!
SECRET_KEY=change-me-to-random-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
DATABASE_URL=sqlite:///data/lampung_monitor.db

# Telegram Bot (opsional - kosongkan jika tidak dipakai)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# Monitoring Intervals (detik)
BMKG_CHECK_INTERVAL=300
NEWS_CHECK_INTERVAL=3600
DISASTER_CHECK_INTERVAL=7200

# Koordinat filter Lampung
LAMPUNG_LAT_MIN=-6.5
LAMPUNG_LAT_MAX=-3.5
LAMPUNG_LON_MIN=103.5
LAMPUNG_LON_MAX=106.0

# Default Superadmin (hanya untuk inisialisasi pertama)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@balmon-lampung.go.id
